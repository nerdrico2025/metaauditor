# Supabase Configuration
# Obtenha estes valores em: https://supabase.com/dashboard/project/[PROJECT_ID]/settings/api
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres"
SUPABASE_PROJECT_ID="your_project_id"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# OpenAI API (para análise de IA)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-xxx"

# Facebook/Meta OAuth Configuration
# Dashboard: https://developers.facebook.com/apps/
# IMPORTANTE: Configure também no Lovable (Settings → Environment Variables) e Supabase Secrets
VITE_META_APP_ID="your_facebook_app_id_here"
VITE_META_APP_SECRET="your_facebook_app_secret_here"

# NOTA: META_APP_SECRET também deve ser configurado como Supabase Secret (sem o prefixo VITE_)
# Use: supabase secrets set META_APP_ID=xxx META_APP_SECRET=xxx
# Ou configure manualmente em: https://supabase.com/dashboard/project/[PROJECT_ID]/settings/functions
